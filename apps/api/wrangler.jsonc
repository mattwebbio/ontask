{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "ontask-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-29",
  // "compatibility_flags": ["nodejs_compat"],

  // ── Environments ──────────────────────────────────────────────────────────
  "env": {
    "staging": {
      "name": "ontask-api-staging",
      "routes": [
        {
          "pattern": "api.staging.ontaskhq.com/*",
          "zone_name": "ontaskhq.com"
        }
      ]
    }
  },

  // ── Bindings ───────────────────────────────────────────────────────────────
  // DATABASE_URL placeholder — real value set in Cloudflare dashboard (never committed).
  // Observability vars — intentionally empty placeholders.
  // Real values set via `wrangler secret put` in CI/CD for staging and production.
  "vars": {
    "DATABASE_URL": "postgresql://placeholder",
    "ENVIRONMENT": "production",
    "GLITCHTIP_DSN": "",
    "POSTHOG_API_KEY": "",
    // Google OAuth2 credentials for Google Calendar integration (Story 3.3).
    // Set via `wrangler secret put GOOGLE_CLIENT_ID` — never committed.
    "GOOGLE_CLIENT_ID": "",
    // Set via `wrangler secret put GOOGLE_CLIENT_SECRET` — never committed.
    "GOOGLE_CLIENT_SECRET": "",
    // 32-byte AES key for encrypting Google Calendar OAuth tokens at rest (NFR-S4).
    // Set via `wrangler secret put CALENDAR_TOKEN_KEY` — never committed.
    "CALENDAR_TOKEN_KEY": "",
    // Secret token echoed back by Google in X-Goog-Channel-Token header on push notifications.
    // Set via `wrangler secret put CALENDAR_WEBHOOK_SECRET` — never committed.
    "CALENDAR_WEBHOOK_SECRET": "",
    // Cloudflare AI Gateway base URL for routing LLM requests through the gateway (Story 3.7).
    // Set via `wrangler secret put AI_GATEWAY_URL` — never committed.
    "AI_GATEWAY_URL": "",
    // Stripe API key for creating off-session PaymentIntents (Story 6.5).
    // Set via `wrangler secret put STRIPE_SECRET_KEY` — never committed.
    "STRIPE_SECRET_KEY": "",
    // Stripe webhook signing secret for verifying webhook event signatures (Story 6.5).
    // Set via `wrangler secret put STRIPE_WEBHOOK_SECRET` — never committed.
    "STRIPE_WEBHOOK_SECRET": "",
    // Every.org Partner Funds API key for charity disbursements (Story 6.5).
    // Set via `wrangler secret put EVERY_ORG_API_KEY` — never committed.
    "EVERY_ORG_API_KEY": "",
    // APNs push notification credentials (Story 8.1, ARCH-27).
    // Set via `wrangler secret put APNS_KEY` — p8 key file contents, never committed.
    "APNS_KEY": "",
    // Set via `wrangler secret put APNS_KEY_ID` — 10-char Key ID from Apple Developer portal.
    "APNS_KEY_ID": "",
    // Set via `wrangler secret put APNS_TEAM_ID` — 10-char Team ID from Apple Developer portal.
    "APNS_TEAM_ID": ""
  },

  // ── Queues ─────────────────────────────────────────────────────────────────
  "queues": {
    "producers": [
      { "queue": "charge-trigger-queue", "binding": "CHARGE_TRIGGER_QUEUE" },
      { "queue": "every-org-queue", "binding": "EVERY_ORG_QUEUE" }
    ],
    "consumers": [
      { "queue": "charge-trigger-queue", "max_batch_size": 10, "max_retries": 3, "dead_letter_queue": "charge-trigger-dlq" },
      { "queue": "every-org-queue", "max_batch_size": 10, "max_retries": 10 }
    ]
  },

  // ── Cron triggers ──────────────────────────────────────────────────────────
  "triggers": {
    "crons": ["*/5 * * * *"]
  }

  // "kv_namespaces": [],
  // "r2_buckets": [],
  // "d1_databases": [],
  // "ai": { "binding": "AI" },
  // "observability": { "enabled": true, "head_sampling_rate": 1 }
}
